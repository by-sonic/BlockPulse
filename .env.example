BP_BOT_TOKEN=your-telegram-bot-token
BP_API_PORT=8080
BP_API_HOST=your-server-ip-or-domain
BP_TARGET_IP=target-vpn-server-ip
BP_DB_PATH=data/blockpulse.db
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BP_HMAC_SECRET=generate-a-random-64-char-hex-string
BP_ADMIN_IDS=123456789
BP_CORS_ORIGIN=https://blockpulse.ru
BP_RETENTION_DAYS=30
BP_PROBE_INTERVAL=300
BP_TG_API_URL=https://your-proxy-for-telegram-api
# Trusted reverse proxy IPs (comma-separated)
BP_TRUSTED_PROXIES=127.0.0.1,::1
